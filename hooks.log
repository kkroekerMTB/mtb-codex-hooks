{"hook_type": "PostToolUse", "payload": {"cwd": "/home/kurtk/codex-hooks-example", "hook_event_name": "PostToolUse", "model": "gpt-5.5", "permission_mode": "default", "session_id": "019f147e-2282-7740-99c9-3eb8d3605be5", "tool_input": {"command": "sed -n '1,220p' .codex/hooks.json"}, "tool_name": "Bash", "tool_response": "{\n  \"hooks\": {\n    \"SessionStart\": [\n      {\n        \"matcher\": \"startup|resume|clear|compact\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"python3 \\\"$(git rev-parse --show-toplevel)/.codex/hooks/log_hook.py\\\" SessionStart\",\n            \"timeout\": 30,\n            \"statusMessage\": \"Logging SessionStart hook\"\n          }\n        ]\n      }\n    ],\n    \"PreToolUse\": [\n      {\n        \"matcher\": \"*\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"python3 \\\"$(git rev-parse --show-toplevel)/.codex/hooks/log_hook.py\\\" PreToolUse\",\n            \"timeout\": 30,\n            \"statusMessage\": \"Logging PreToolUse hook\"\n          }\n        ]\n      }\n    ],\n    \"PermissionRequest\": [\n      {\n        \"matcher\": \"*\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"python3 \\\"$(git rev-parse --show-toplevel)/.codex/hooks/log_hook.py\\\" PermissionRequest\",\n            \"timeout\": 30,\n            \"statusMessage\": \"Logging PermissionRequest hook\"\n          }\n        ]\n      }\n    ],\n    \"PostToolUse\": [\n      {\n        \"matcher\": \"*\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"python3 \\\"$(git rev-parse --show-toplevel)/.codex/hooks/log_hook.py\\\" PostToolUse\",\n            \"timeout\": 30,\n            \"statusMessage\": \"Logging PostToolUse hook\"\n          }\n        ]\n      }\n    ],\n    \"PreCompact\": [\n      {\n        \"matcher\": \"manual|auto\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"python3 \\\"$(git rev-parse --show-toplevel)/.codex/hooks/log_hook.py\\\" PreCompact\",\n            \"timeout\": 30,\n            \"statusMessage\": \"Logging PreCompact hook\"\n          }\n        ]\n      }\n    ],\n    \"PostCompact\": [\n      {\n        \"matcher\": \"manual|auto\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"python3 \\\"$(git rev-parse --show-toplevel)/.codex/hooks/log_hook.py\\\" PostCompact\",\n            \"timeout\": 30,\n            \"statusMessage\": \"Logging PostCompact hook\"\n          }\n        ]\n      }\n    ],\n    \"UserPromptSubmit\": [\n      {\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"python3 \\\"$(git rev-parse --show-toplevel)/.codex/hooks/log_hook.py\\\" UserPromptSubmit\",\n            \"timeout\": 30,\n            \"statusMessage\": \"Logging UserPromptSubmit hook\"\n          }\n        ]\n      }\n    ],\n    \"SubagentStart\": [\n      {\n        \"matcher\": \"*\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"python3 \\\"$(git rev-parse --show-toplevel)/.codex/hooks/log_hook.py\\\" SubagentStart\",\n            \"timeout\": 30,\n            \"statusMessage\": \"Logging SubagentStart hook\"\n          }\n        ]\n      }\n    ],\n    \"SubagentStop\": [\n      {\n        \"matcher\": \"*\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"python3 \\\"$(git rev-parse --show-toplevel)/.codex/hooks/log_hook.py\\\" SubagentStop\",\n            \"timeout\": 30,\n            \"statusMessage\": \"Logging SubagentStop hook\"\n          }\n        ]\n      }\n    ],\n    \"Stop\": [\n      {\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"python3 \\\"$(git rev-parse --show-toplevel)/.codex/hooks/log_hook.py\\\" Stop\",\n            \"timeout\": 30,\n            \"statusMessage\": \"Logging Stop hook\"\n          }\n        ]\n      }\n    ]\n  }\n}\n", "tool_use_id": "call_Yzm7tS80tMLPg06RDJBhG8Wa", "transcript_path": "/home/kurtk/.codex/sessions/2026/06/29/rollout-2026-06-29T13-47-18-019f147e-2282-7740-99c9-3eb8d3605be5.jsonl", "turn_id": "019f147e-b38b-7f60-ba6d-3bcbfd44070c"}, "timestamp": "2026-06-29T17:48:07.609058+00:00"}
{"hook_type": "PostToolUse", "payload": {"cwd": "/home/kurtk/codex-hooks-example", "hook_event_name": "PostToolUse", "model": "gpt-5.5", "permission_mode": "default", "session_id": "019f147e-2282-7740-99c9-3eb8d3605be5", "tool_input": {"command": "sed -n '1,240p' .codex/hooks/log_hook.py"}, "tool_name": "Bash", "tool_response": "#!/usr/bin/env python3\n\"\"\"Append Codex hook invocations to hooks.log as JSON lines.\"\"\"\n\nfrom __future__ import annotations\n\nimport fcntl\nimport json\nimport subprocess\nimport sys\nfrom datetime import datetime, timezone\nfrom pathlib import Path\n\n\ndef git_root() -> Path:\n    try:\n        result = subprocess.run(\n            [\"git\", \"rev-parse\", \"--show-toplevel\"],\n            check=True,\n            capture_output=True,\n            text=True,\n        )\n    except (subprocess.CalledProcessError, FileNotFoundError):\n        return Path.cwd()\n\n    return Path(result.stdout.strip())\n\n\ndef read_payload() -> object:\n    raw_payload = sys.stdin.read()\n    if not raw_payload:\n        return None\n\n    try:\n        return json.loads(raw_payload)\n    except json.JSONDecodeError:\n        return raw_payload\n\n\ndef main() -> int:\n    hook_type = sys.argv[1] if len(sys.argv) > 1 else \"unknown\"\n    record = {\n        \"timestamp\": datetime.now(timezone.utc).isoformat(),\n        \"hook_type\": hook_type,\n        \"payload\": read_payload(),\n    }\n\n    log_path = git_root() / \"hooks.log\"\n    with log_path.open(\"a\", encoding=\"utf-8\") as log_file:\n        fcntl.flock(log_file.fileno(), fcntl.LOCK_EX)\n        log_file.write(json.dumps(record, sort_keys=True) + \"\\n\")\n        log_file.flush()\n        fcntl.flock(log_file.fileno(), fcntl.LOCK_UN)\n\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n", "tool_use_id": "call_BysBB8iivrZhL9peSWcpWPDY", "transcript_path": "/home/kurtk/.codex/sessions/2026/06/29/rollout-2026-06-29T13-47-18-019f147e-2282-7740-99c9-3eb8d3605be5.jsonl", "turn_id": "019f147e-b38b-7f60-ba6d-3bcbfd44070c"}, "timestamp": "2026-06-29T17:48:07.633309+00:00"}
