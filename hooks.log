\\": read_payload(),\\n    }\\n\\n    log_path = git_root() / \\\"hooks.log\\\"\\n    with log_path.open(\\\"a\\\", encoding=\\\"utf-8\\\") as log_file:\\n        fcntl.flock(log_file.fileno(), fcntl.LOCK_EX)\\n        log_file.write(json.dumps(record, sort_keys=True) + \\\"\\\\n\\\")\\n        log_file.flush()\\n        fcntl.flock(log_file.fileno(), fcntl.LOCK_UN)\\n\\n    return 0\\n\\n\\nif __name__ == \\\"__main__\\\":\\n    raise SystemExit(main())\\n\", \"tool_use_id\": \"call_BysBB8iivrZhL9peSWcpWPDY\", \"transcript_path\": \"/home/kurtk/.codex/sessions/2026/06/29/rollout-2026-06-29T13-47-18-019f147e-2282-7740-99c9-3eb8d3605be5.jsonl\", \"turn_id\": \"019f147e-b38b-7f60-ba6d-3bcbfd44070c\"}, \"timestamp\": \"2026-06-29T17:48:07.633309+00:00\"}\n{\"hook_type\": \"PostToolUse\", \"payload\": {\"cwd\": \"/home/kurtk/codex-hooks-example\", \"hook_event_name\": \"PostToolUse\", \"model\": \"gpt-5.5\", \"permission_mode\": \"default\", \"session_id\": \"019f147e-2282-7740-99c9-3eb8d3605be5\", \"tool_input\": {\"command\": \"tail -n 80 hooks.log\"}, \"tool_name\": \"Bash\", \"tool_response\": \"{\\\"hook_type\\\": \\\"ManualTest\\\", \\\"payload\\\": {\\\"sample\\\": true, \\\"tool\\\": \\\"manual\\\"}, \\\"timestamp\\\": \\\"2026-06-29T17:38:09.900600+00:00\\\"}\\n{\\\"hook_type\\\": \\\"SessionStart\\\", \\\"payload\\\": {\\\"cwd\\\": \\\"/home/kurtk/codex-hooks-example\\\", \\\"hook_event_name\\\": \\\"SessionStart\\\", \\\"model\\\": \\\"gpt-5.5\\\", \\\"permission_mode\\\": \\\"default\\\", \\\"session_id\\\": \\\"019f147e-2282-7740-99c9-3eb8d3605be5\\\", \\\"source\\\": \\\"startup\\\", \\\"transcript_path\\\": \\\"/home/kurtk/.codex/sessions/2026/06/29/rollout-2026-06-29T13-47-18-019f147e-2282-7740-99c9-3eb8d3605be5.jsonl\\\"}, \\\"timestamp\\\": \\\"2026-06-29T17:47:22.835059+00:00\\\"}\\n{\\\"hook_type\\\": \\\"UserPromptSubmit\\\", \\\"payload\\\": {\\\"cwd\\\": \\\"/home/kurtk/codex-hooks-example\\\", \\\"hook_event_name\\\": \\\"UserPromptSubmit\\\", \\